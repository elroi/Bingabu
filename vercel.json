{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "git": {
    "deploymentEnabled": {
      "**": false,
      "main": true
    }
  },
  "functions": {
    "api/**/*.js": {
      "includeFiles": "locales/**"
    }
  },
  "rewrites": [
    { "source": "/j/:code", "destination": "/join.html?join=:code" },
    { "source": "/api/health", "destination": "/api/lobby?health=1" }
  ]
}
