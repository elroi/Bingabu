{
  "name": "bingabu",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "serve .",
    "predev:api": "npm run build",
    "dev:api": "vercel dev",
    "build": "vite build && mkdir -p dist/locales && cp locales/*.json dist/locales/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:reuse": "E2E_SKIP_WEBSERVER=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare:e2e": "playwright install chromium",
    "dev:e2e": "npx vercel dev --listen 127.0.0.1:3000 --local-config vercel.e2e.json"
  },
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.34.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jsdom": "^24.1.3",
    "serve": "^14.2.4",
    "vercel": "^39.0.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
